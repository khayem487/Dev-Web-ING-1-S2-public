# Copy this file to .env (gitignored) and fill in real values.
# Dev baseline uses H2 in-memory so no DB credentials are required to start.

# --- Backend (Spring Boot) ---
SERVER_PORT=8080

# Vérification email (obligatoire)
APP_AUTH_EMAIL_VERIFICATION_ENABLED=true
# Option debug (dev only) : renvoie aussi le token dans la réponse API
APP_AUTH_EMAIL_VERIFICATION_DEBUG_TOKEN_ENABLED=false

# SMTP (obligatoire pour envoi réel du code)
# Exemple Gmail: host=smtp.gmail.com port=587 auth=true starttls=true
APP_MAIL_HOST=
APP_MAIL_PORT=587
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_SMTP_AUTH=true
APP_MAIL_SMTP_STARTTLS=true
APP_MAIL_FROM=
APP_MAIL_APP_NAME=Maison Intelligente

# MySQL (activer plus tard, quand mysql-connector-j sera décommenté dans pom.xml)
# DB_URL=jdbc:mysql://localhost:3306/maison_intelligente?useSSL=false&serverTimezone=UTC
# DB_USERNAME=root
# DB_PASSWORD=

# --- Frontend (Vite) ---
# Laissez vide en dev : Vite proxy /api vers http://localhost:8080 (voir vite.config.js)
# VITE_API_BASE_URL=http://localhost:8080
