# Copy this file to .env (gitignored) and fill in real values.
# Dev baseline uses H2 in-memory so no DB credentials are required to start.

# --- Backend (Spring Boot) ---
SERVER_PORT=8080

# MySQL (activer plus tard, quand mysql-connector-j sera décommenté dans pom.xml)
# DB_URL=jdbc:mysql://localhost:3306/maison_intelligente?useSSL=false&serverTimezone=UTC
# DB_USERNAME=root
# DB_PASSWORD=

# --- Frontend (Vite) ---
# Laissez vide en dev : Vite proxy /api vers http://localhost:8080 (voir vite.config.js)
# VITE_API_BASE_URL=http://localhost:8080
